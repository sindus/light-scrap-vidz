{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "light-scrap-vidZ",
  "version": "0.2.4",
  "identifier": "com.lightscrape.vidz",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "light-scrap-vidZ",
        "width": 960,
        "height": 680,
        "minWidth": 700,
        "minHeight": 560,
        "resizable": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": ["ffmpeg", "yt-dlp"]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVFMjU1OUM5RjBDN0Q4Q0MKUldUTTJNZnd5VmtsWHJKakZJTWZHWm9MaU1MRTlKODJGbWIvUEU5MC9NKzBoSUp3akNEN2kwY0gK",
      "endpoints": [
        "https://github.com/sindus/light-scrap-vidz/releases/latest/download/latest.json"
      ]
    }
  }
}
